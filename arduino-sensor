#include <WiFi.h>
#include <WiFiClient.h>
#include "esp_eap_client.h" 

// --- ข้อมูลการเชื่อมต่อ ---
const char* ssid = "KMITL-Legacy"; 
const char* eap_username = "67011063";
const char* eap_password = "Boom.kmitl25249";
const char* server = "10.26.11.197";
const int port = 8080;

// --- ขา Pin (ตรวจสอบการต่อสายให้ตรงกับเลขนี้) ---
const int trigPin = 4;
const int echoPin = 5;

long duration;
float distanceCm;
float minDistance = 9999;
float maxDistance = 0;

void setup() {
  // เริ่มต้น Serial และรอให้ Monitor พร้อม
  Serial.begin(115200);
  delay(2000); 
  Serial.println("\n\n===========================");
  Serial.println("System Starting...");
  Serial.println("===========================");

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  Serial.println("Configuring WiFi Enterprise...");
  WiFi.disconnect(true);
  WiFi.mode(WIFI_STA);

  // ตั้งค่า WPA2 Enterprise (Core 3.0+)
  esp_eap_client_set_identity((uint8_t *)eap_username, strlen(eap_username));
  esp_eap_client_set_username((uint8_t *)eap_username, strlen(eap_username));
  esp_eap_client_set_password((uint8_t *)eap_password, strlen(eap_password));
  esp_eap_client_set_ca_cert(NULL, 0); 
  
  esp_wifi_sta_enterprise_enable(); 
  
  Serial.print("Connecting to: ");
  Serial.println(ssid);
  WiFi.begin(ssid);
  
  // ถ้าค้างที่จุดนี้ แสดงว่ารหัส WiFi หรือสัญญาณมีปัญหา
  int retry_count = 0;
  while (WiFi.status() != WL_CONNECTED) {
    delay(1000);
    Serial.print(".");
    retry_count++;
    if(retry_count > 30) { // ถ้าเกิน 30 วินาทีให้ลองเริ่มใหม่
      Serial.println("\nWiFi Connect Failed! Rebooting...");
      ESP.restart();
    }
  }
  
  Serial.println("\n✅ WiFi Connected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());
}

float readDistance() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // ถ้าระยะอ่านไม่ได้ (Timeout) จะคืนค่า 0
  long localDuration = pulseIn(echoPin, HIGH, 30000); 
  if (localDuration == 0) return 0;
  return (localDuration * 0.0343) / 2;
}

void loop() {
  distanceCm = readDistance();
  
  if (distanceCm > 0) { // ตรวจสอบว่า Sensor อ่านค่าได้จริง
    if (distanceCm < minDistance) minDistance = distanceCm;
    if (distanceCm > maxDistance) maxDistance = distanceCm;

    String json = "{";
    json += "\"id\":1,";
    json += "\"x\":" + String(distanceCm, 2) + ",";
    json += "\"y\":" + String(minDistance, 2) + ",";
    json += "\"z\":" + String(maxDistance, 2);
    json += "}";

    Serial.print("Data to send: ");
    Serial.println(json);

    WiFiClient client;
    if (client.connect(server, port)) {
      client.println("POST /data HTTP/1.1");
      client.println("Host: " + String(server));
      client.println("Content-Type: application/json");
      client.print("Content-Length: ");
      client.println(json.length());
      client.println();
      client.println(json);
      client.stop();
      Serial.println(">>> ✅ Sent to Bridge");
    } else {
      Serial.println(">>> ❌ Server Connection Failed (Check Server IP/Port)");
    }
  } else {
    Serial.println("⚠️ Sensor Error: Cannot read distance");
  }

  delay(5000); // เวลารอระหว่างรอบ
}
